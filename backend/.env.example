RUNTIME_AGENT_ID=hr-agent-runtime
RUNTIME_AGENT_VERSION=v1
RUNTIME_AGENT_CATALOG_JSON=[]

# Bootstrap runtime registration lifecycle automatically on startup.
RUNTIME_BOOTSTRAP_REGISTER_ON_STARTUP=true
RUNTIME_BOOTSTRAP_VALIDATE_REGISTRATION=true
RUNTIME_BOOTSTRAP_ACTIVATE_REGISTRATION=true
RUNTIME_BOOTSTRAP_EXECUTION_MODE=remote_runtime
RUNTIME_BOOTSTRAP_AUTH_MODE=jwt
RUNTIME_BOOTSTRAP_RUNTIME_ID=your-machine-client-runtime-id
RUNTIME_BOOTSTRAP_ENDPOINT_URL=http://simpleflow-hr-runtime:8091
RUNTIME_PUBLIC_BASE_URL=http://simpleflow-hr-runtime:8091

# Optional control-plane client settings.
# Use Docker service name when this runtime runs in Compose.
SIMPLEFLOW_API_BASE_URL=http://backend:8080
SIMPLEFLOW_RUNTIME_REGISTER_PATH=/v1/runtime/connect
# Control-plane backend security settings (configure on SimpleFlow backend service):
# PUBLIC_BASE_URL=http://localhost:8080
# RUNTIME_ENDPOINT_ALLOWLIST=simpleflow-hr-runtime,localhost
# Preferred (SaaS-style): machine client credentials (auto token fetch via /v1/oauth/token).
SIMPLEFLOW_CLIENT_ID=
SIMPLEFLOW_CLIENT_SECRET=
# Legacy fallback bearer token (not recommended for production).
SIMPLEFLOW_API_TOKEN=

# Invoke trust defaults to enabled for control-plane-only chat flow.
RUNTIME_INVOKE_TRUST_ENABLED=true
RUNTIME_INVOKE_TOKEN_ISSUER=simpleflow-runtime
RUNTIME_INVOKE_TOKEN_AUDIENCE=simpleflow-runtime
# Verify control-plane tokens via JWKS.
RUNTIME_INVOKE_TOKEN_JWKS_URL=http://backend:8080/.well-known/runtime-invoke-jwks.json

# Workflow execution config.
WORKFLOW_ROOT=/workspace/workflows
WORKFLOW_ENTRY_FILE=email-chat-orchestrator-with-subgraph-tool.yaml
SIMPLE_AGENTS_PROVIDER=openai
CUSTOM_API_BASE=
CUSTOM_API_KEY=

# CORS for browser chat UI.
RUNTIME_CORS_ALLOW_ORIGINS=http://localhost:5175,http://localhost:5173
